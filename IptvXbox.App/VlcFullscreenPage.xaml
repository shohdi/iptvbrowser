<Page
    x:Class="IptvXbox.App.VlcFullscreenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vlc="using:LibVLCSharp.Platforms.UWP"
    mc:Ignorable="d"
    Background="Black">

    <Grid Background="Black">
        <vlc:VideoView x:Name="VlcPlayerView"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Initialized="VlcPlayerView_Initialized" />

        <Grid x:Name="InteractionSurface"
              Background="#01000000"
              Tapped="InteractionSurface_Tapped"
              KeyDown="InteractionSurface_KeyDown">
            <Grid x:Name="ControlsOverlay">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,20,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleTextBlock"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords" />

                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Content="X"
                            Width="56"
                            Height="56"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="CloseButton_Click" />
                </Grid>

                <Border Grid.Row="2"
                        Margin="20,0,20,20"
                        Padding="20,14"
                        Background="#AA000000"
                        CornerRadius="14">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <Button x:Name="BackThirtyButton"
                                Content="-30s"
                                Click="BackThirtyButton_Click" />
                        <Button x:Name="PlayPauseButton"
                                Content="Pause"
                                Click="PlayPauseButton_Click" />
                        <Button x:Name="ForwardThirtyButton"
                                Content="+30s"
                                Click="ForwardThirtyButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
