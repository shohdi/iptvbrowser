<Page
    x:Class="IptvXbox.App.BrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IptvXbox.App.Models"
    xmlns:vlc="using:LibVLCSharp.Platforms.UWP"
    mc:Ignorable="d"
    Background="{StaticResource ShellBackgroundBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*" />
            <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="10">
            <TextBlock Text="Browse" FontSize="34" FontWeight="SemiBold" />
            <TextBlock Text="Navigate Live, Movies, and Series with cards. Open a section, then a category, then choose something to play." Opacity="0.8" />
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,20,16,0"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock x:Name="NodeTitleTextBlock" Text="Browse Library" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock x:Name="NodeSubtitleTextBlock" Text="Choose Live, Movies, or Series." Opacity="0.8" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,18,0,18">
                    <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" IsEnabled="False" />
                    <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" />
                </StackPanel>

                <GridView x:Name="BrowseGridView"
                          Grid.Row="2"
                          IsItemClickEnabled="True"
                          ItemClick="BrowseGridView_ItemClick"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:BrowseCard">
                            <Border Width="260"
                                    Height="220"
                                    Margin="8"
                                    Padding="14"
                                    Background="#172033"
                                    CornerRadius="18"
                                    BorderBrush="#243244"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="110" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#1E293B" CornerRadius="14">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,12,0,0"
                                               Text="{Binding Title}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2" />

                                    <TextBlock Grid.Row="2"
                                               Margin="0,8,0,0"
                                               Text="{Binding Subtitle}"
                                               Opacity="0.8"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="3" />

                                    <Border Grid.Row="3"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"
                                            Padding="10,4"
                                            Background="#1D4ED8"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding Badge}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="0,20,0,0"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Player" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="SelectionTextBlock"
                           Grid.Row="1"
                           Margin="0,10,0,10"
                           Text="Choose a card to start browsing or playback."
                           TextWrapping="WrapWholeWords" />

                <StackPanel Grid.Row="2"
                            x:Name="PlaybackButtonsPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                    <Button x:Name="PlayButton"
                            Content="Play"
                            Click="PlayButton_Click" />
                    <Button x:Name="PlayWithVlcButton"
                            Content="Play on VLC"
                            Click="PlayWithVlcButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            x:Name="SeriesSelectorsPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                    <ComboBox x:Name="SeasonComboBox"
                              Header="Season"
                              SelectionChanged="SeasonComboBox_SelectionChanged" />
                    <ComboBox x:Name="EpisodeComboBox"
                              Header="Episode"
                              SelectionChanged="EpisodeComboBox_SelectionChanged" />
                    <Button Content="Play Episode" Click="PlayEpisodeButton_Click" />
                    <Button Content="Play Episode on VLC" Click="PlayEpisodeWithVlcButton_Click" />
                </StackPanel>

                <MediaPlayerElement x:Name="PlayerElement"
                                    Grid.Row="4"
                                    Margin="0,14,0,0"
                                    MinHeight="320"
                                    AreTransportControlsEnabled="True"
                                    AutoPlay="False" />
                <vlc:VideoView x:Name="VlcPlayerView"
               Grid.Row="4"
               Margin="0,14,0,0"
               MinHeight="320"
               HorizontalAlignment="Stretch" 
               VerticalAlignment="Stretch"
               Initialized="VlcPlayerView_Initialized" />
            </Grid>
        </Border>
    </Grid>
</Page>
