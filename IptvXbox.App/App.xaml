<Application
    x:Class="IptvXbox.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="ShellBackgroundColor">#FF0F172A</Color>
            <Color x:Key="SurfaceColor">#FF111827</Color>
            <Color x:Key="AccentColor">#FFF59E0B</Color>
            <Color x:Key="TextColor">#FFF8FAFC</Color>

            <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>

            <DataTemplate x:Key="WhiteHeaderTemplate">
                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
            </DataTemplate>

            <Style TargetType="TextBox">
                <Setter Property="HeaderTemplate" Value="{StaticResource WhiteHeaderTemplate}" />
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="HeaderTemplate" Value="{StaticResource WhiteHeaderTemplate}" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="HeaderTemplate" Value="{StaticResource WhiteHeaderTemplate}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
