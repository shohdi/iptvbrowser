<Page
    x:Class="IptvXbox.App.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IptvXbox.App.Models"
    xmlns:vlc="using:LibVLCSharp.Platforms.UWP"
    mc:Ignorable="d"
    Background="{StaticResource ShellBackgroundBrush}">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedItemsSource"
                              IsSourceGrouped="True"
                              Source="{x:Bind GroupedItems}" />
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*" />
            <ColumnDefinition Width="1.6*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="10">
            <TextBlock Text="Search" FontSize="34" FontWeight="SemiBold" />
            <TextBlock Text="Search the currently loaded IPTV catalog. Load or refresh data from the Login page first." Opacity="0.8" />
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,20,16,0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="18,16,18,0" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox x:Name="SearchTextBox"
                                 Width="340"
                                 Header="Search"
                                 PlaceholderText="Search channels, movies, or series"
                                 TextChanged="SearchTextBox_TextChanged" />
                        <ComboBox x:Name="ContentTypeComboBox"
                                  Width="170"
                                  Header="Type"
                                  SelectionChanged="Filters_Changed">
                            <ComboBoxItem Content="All" Tag="All" IsSelected="True" />
                            <ComboBoxItem Content="Live" Tag="Live" />
                            <ComboBoxItem Content="Movies" Tag="Movie" />
                            <ComboBoxItem Content="Series" Tag="Series" />
                        </ComboBox>
                        <ComboBox x:Name="SortComboBox"
                                  Width="190"
                                  Header="Sort"
                                  SelectionChanged="Filters_Changed">
                            <ComboBoxItem Content="A to Z" Tag="NameAsc" IsSelected="True" />
                            <ComboBoxItem Content="Z to A" Tag="NameDesc" />
                        </ComboBox>
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock" Text="Ready" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Margin="18,16,18,8"
                           Text="Catalog"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <ListView x:Name="CatalogListView"
                          Grid.Row="2"
                          Margin="6,0,6,6"
                          IsItemClickEnabled="True"
                          ItemClick="CatalogListView_ItemClick"
                          SelectionMode="Single"
                          ItemsSource="{Binding Source={StaticResource GroupedItemsSource}}">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#172554" Padding="12,8" Margin="0,10,0,0" CornerRadius="10">
                                        <TextBlock Text="{Binding Key}" FontSize="18" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CatalogItem">
                            <Grid Margin="8,8,8,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="72" Height="72" CornerRadius="12" Background="#1E293B">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="14,0,0,0" Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding Subtitle}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding StreamKindLabel}" Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="0,20,0,0"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Player" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="SelectionTextBlock"
                           Grid.Row="1"
                           Margin="0,10,0,10"
                           Text="Select an item to start playback."
                           TextWrapping="WrapWholeWords" />

                <StackPanel Grid.Row="2"
                            x:Name="PlaybackButtonsPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                    <Button x:Name="PlayButton"
                            Content="Play"
                            Click="PlayButton_Click" />
                    <Button x:Name="PlayWithVlcButton"
                            Content="Play on VLC"
                            Click="PlayWithVlcButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            x:Name="SeriesSelectorsPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                    <ComboBox x:Name="SeasonComboBox"
                              Header="Season"
                              SelectionChanged="SeasonComboBox_SelectionChanged" />
                    <ComboBox x:Name="EpisodeComboBox"
                              Header="Episode"
                              SelectionChanged="EpisodeComboBox_SelectionChanged" />
                    <Button x:Name="PlayEpisodeButton"
                            Content="Play Episode"
                            Click="PlayEpisodeButton_Click" />
                    <Button x:Name="PlayEpisodeWithVlcButton"
                            Content="Play Episode on VLC"
                            Click="PlayEpisodeWithVlcButton_Click" />
                </StackPanel>

                <MediaPlayerElement x:Name="PlayerElement"
                                    Grid.Row="4"
                                    Margin="0,14,0,0"
                                    MinHeight="320"
                                    AreTransportControlsEnabled="True"
                                    AutoPlay="False" />
                <vlc:VideoView x:Name="VlcPlayerView"
                               Grid.Row="4"
                               Margin="0,14,0,0"
                               MinHeight="320"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Initialized="VlcPlayerView_Initialized" />
            </Grid>
        </Border>
    </Grid>
</Page>
