<Page
    x:Class="IptvXbox.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IptvXbox.App.Models"
    mc:Ignorable="d"
    Background="{StaticResource ShellBackgroundBrush}">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedItemsSource"
                              IsSourceGrouped="True"
                              Source="{x:Bind GroupedItems}" />
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*" />
            <ColumnDefinition Width="1.6*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="10">
            <TextBlock Text="IPTV Browser" FontSize="34" FontWeight="SemiBold" />
            <TextBlock Text="Fast channel browsing for live TV, movies, and series on Windows and Xbox." Opacity="0.8" />
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,20,16,16"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <StackPanel Spacing="12">
                <TextBlock Text="Source" FontSize="20" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox x:Name="ServerTextBox" Width="240" Header="Server" PlaceholderText="http://server:port" />
                    <TextBox x:Name="UsernameTextBox" Width="170" Header="Username" />
                    <PasswordBox x:Name="PasswordTextBox" Width="170" Header="Password" />
                    <Button Content="Refresh API" Click="RefreshApiButton_Click" />
                    <Button Content="Load channels.json" Click="LoadLocalFileButton_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox x:Name="SearchTextBox"
                             Width="340"
                             Header="Search"
                             PlaceholderText="Search channels, movies, or series"
                             TextChanged="SearchTextBox_TextChanged" />
                    <ComboBox x:Name="ContentTypeComboBox"
                              Width="170"
                              Header="Type"
                              SelectionChanged="Filters_Changed">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True" />
                        <ComboBoxItem Content="Live" Tag="Live" />
                        <ComboBoxItem Content="Movies" Tag="Movie" />
                        <ComboBoxItem Content="Series" Tag="Series" />
                    </ComboBox>
                    <ComboBox x:Name="SortComboBox"
                              Width="190"
                              Header="Sort"
                              SelectionChanged="Filters_Changed">
                        <ComboBoxItem Content="A to Z" Tag="NameAsc" IsSelected="True" />
                        <ComboBoxItem Content="Z to A" Tag="NameDesc" />
                    </ComboBox>
                    <TextBlock x:Name="StatusTextBlock"
                               VerticalAlignment="Bottom"
                               Margin="8,0,0,4"
                               Text="Ready" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.RowSpan="2"
                Margin="0,20,0,0"
                Padding="18"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Player" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="SelectionTextBlock"
                           Grid.Row="1"
                           Margin="0,10,0,10"
                           Text="Select an item to start playback."
                           TextWrapping="WrapWholeWords" />

                <StackPanel Grid.Row="2"
                            x:Name="SeriesSelectorsPanel"
                            Orientation="Horizontal"
                            Spacing="12"
                            Visibility="Collapsed">
                    <ComboBox x:Name="SeasonComboBox"
                              Width="160"
                              Header="Season"
                              SelectionChanged="SeasonComboBox_SelectionChanged" />
                    <ComboBox x:Name="EpisodeComboBox"
                              Width="240"
                              Header="Episode"
                              SelectionChanged="EpisodeComboBox_SelectionChanged" />
                    <Button x:Name="PlayEpisodeButton"
                            Content="Play Episode"
                            Click="PlayEpisodeButton_Click" />
                </StackPanel>

                <MediaPlayerElement x:Name="PlayerElement"
                                    Grid.Row="3"
                                    Margin="0,14,0,0"
                                    AreTransportControlsEnabled="True"
                                    AutoPlay="False" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Margin="0,0,16,0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Margin="18,16,18,8"
                           Text="Catalog"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <ListView x:Name="CatalogListView"
                          Grid.Row="1"
                          Margin="6,0,6,6"
                          IsItemClickEnabled="True"
                          ItemClick="CatalogListView_ItemClick"
                          SelectionMode="Single"
                          ItemsSource="{Binding Source={StaticResource GroupedItemsSource}}">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#172554" Padding="12,8" Margin="0,10,0,0" CornerRadius="10">
                                        <TextBlock Text="{Binding Key}" FontSize="18" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CatalogItem">
                            <Grid Margin="8,8,8,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="72" Height="72" CornerRadius="12" Background="#1E293B">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="14,0,0,0" Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding Subtitle}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding StreamKindLabel}" Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
